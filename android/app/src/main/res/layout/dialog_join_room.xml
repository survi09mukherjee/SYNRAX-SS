<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface">

    <!-- Manual Code Input -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Room Code (e.g. FE7A2)"
        app:boxStrokeColor="@color/primary"
        app:hintTextColor="@color/primary"
        android:textColorHint="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_dialog_room_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapCharacters"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Optional Passcode -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:hint="Passcode (optional)"
        app:boxStrokeColor="@color/primary"
        app:hintTextColor="@color/primary"
        android:textColorHint="@color/text_secondary"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_dialog_passcode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Or join instantly via camera scan:"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- Barcode scan launch trigger -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dialog_scan_qr"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Scan QR Code"
        android:textColor="@color/accent"
        app:strokeColor="@color/accent"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconTint="@color/accent"
        app:cornerRadius="8dp" />
</LinearLayout>
