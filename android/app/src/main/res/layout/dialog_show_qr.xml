<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/surface">

    <TextView
        android:id="@+id/txt_qr_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join Room QR Code"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Pure white background for scanner readability -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="250dp"
        android:layout_height="250dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="0dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/img_qr_code"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:contentDescription="Event QR Code" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txt_qr_code_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Room Code: ------"
        android:textColor="@color/accent"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_qr"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Close"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary"
        app:cornerRadius="8dp" />
</LinearLayout>
