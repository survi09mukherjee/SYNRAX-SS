<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.synrax.ss">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Required for scanning / storage pickers -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SYNRAXSS"
        android:usesCleartextTraffic="true"> <!-- Allow HTTP requests for local loopback testing -->

        <!-- Splash Launcher Activity -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth Activities -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />
        <activity
            android:name=".ui.SignupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />

        <!-- Home Activity -->
        <activity
            android:name=".ui.HomeActivity"
            android:exported="false"
            android:label="SYNRAX SS"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />

        <!-- Create Event Room Activity -->
        <activity
            android:name=".ui.CreateEventActivity"
            android:exported="false"
            android:label="Create Room"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />

        <!-- Realtime Event Gallery Activity -->
        <activity
            android:name=".ui.EventGalleryActivity"
            android:exported="false"
            android:label="Event Gallery"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />

        <!-- Full-screen Photo Zoom View Activity -->
        <activity
            android:name=".ui.PhotoViewActivity"
            android:exported="false"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />

        <!-- Profile Screen Activity -->
        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false"
            android:label="My Profile"
            android:theme="@style/Theme.SYNRAXSS.NoActionBar" />

        <!-- FileProvider for secure Camera integration -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.synrax.ss.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
