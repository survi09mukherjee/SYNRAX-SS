# FastAPI configurations
APP_NAME=SYNRAX_SS
DEBUG=True
HOST=127.0.0.1
PORT=8000

# Authentication (generate a secure random key using: openssl rand -hex 32)
SECRET_KEY=9a15f9b4de8e7bc9f1c7d23a49e67d26bb87d89abfd3f295e8dc9c049e623db2
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (PostgreSQL URL or SQLite file path)
# Examples: 
# - PostgreSQL: postgresql://postgres:postgres@localhost:5432/synrax_db
# - SQLite: sqlite:///./synrax_ss.db
DATABASE_URL=sqlite:///./synrax_ss.db

# Storage configurations (local or firebase)
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./uploads

# Firebase Configurations (Required if STORAGE_PROVIDER=firebase)
FIREBASE_STORAGE_BUCKET=synrax-ss.appspot.com
FIREBASE_CREDENTIALS_JSON=

# AI configurations
# Hamming distance threshold for duplicate image detection (lower is stricter, e.g., 0-5)
DUPLICATE_THRESHOLD=4
# Confidence threshold for face detection
FACE_CONFIDENCE_THRESHOLD=0.5
